	</dataset>

	<parameter name="salesRecords" class="java.util.Collection"/>
	<parameter name="shareRecords" class="java.util.Collection"/>
	<parameter name="pointRecords" class="java.util.Collection"/>
	<parameter name="funnelRecords" class="java.util.Collection"/>
	<parameter name="gaugeRecords" class="java.util.Collection"/>
	<parameter name="nodeRecords" class="java.util.Collection"/>
	<parameter name="flowRecords" class="java.util.Collection"/>
	<parameter name="routeRecords" class="java.util.Collection"/>
	<parameter name="boxRecords" class="java.util.Collection"/>
	<parameter name="ohlcRecords" class="java.util.Collection"/>
	<parameter name="heatRecords" class="java.util.Collection"/>
	<parameter name="geoRecords" class="java.util.Collection"/>
	<parameter name="customOption" class="java.lang.String"/>
	<parameter name="heatmapOption" class="java.lang.String"/>

	<title height="80">
		<element kind="staticText" uuid="1e000000-0000-0000-0000-000000000001" x="0" y="0" width="535" height="30" fontSize="20.0" bold="true" hTextAlign="Center">
			<text><![CDATA[Charteon Chart Overview]]></text>
		</element>
		<element kind="staticText" uuid="1e000000-0000-0000-0000-000000000002" x="0" y="34" width="535" height="40" fontSize="10.0" hTextAlign="Center">
			<text><![CDATA[Every Apache ECharts core series type, rendered by the Charteon component. In the PDF export all charts are true vector graphics; in the HTML export they are fully interactive.]]></text>
		</element>
	</title>

	<detail>

		<!-- ===================== A. BASIC ===================== -->
		<band height="40">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000000901" x="0" y="0" width="535" height="36" fontSize="16.0" bold="true">
				<text><![CDATA[A. Basic charts]]></text>
			</element>
		</band>

		<!-- 1. Bar -->
		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000000101" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[1. Bar (chartType="bar" showValues="true") — one series per product, value labels on the bars]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000000102" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="bar" showValues="true">
					<titleExpression><![CDATA["Monthly Sales by Product"]]></titleExpression>
					<subtitleExpression><![CDATA["units sold"]]></subtitleExpression>
					<categoryDataset>
						<datasetRun uuid="2e000000-0000-0000-0000-000000000103" subDataset="sales">
							<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRMapCollectionDataSource($P{salesRecords})]]></dataSourceExpression>
						</datasetRun>
						<series>
							<seriesExpression><![CDATA[$F{product}]]></seriesExpression>
							<categoryExpression><![CDATA[$F{month}]]></categoryExpression>
							<valueExpression><![CDATA[$F{amount}]]></valueExpression>
						</series>
					</categoryDataset>
				</component>
			</element>
		</band>

		<!-- 2. Stacked bar -->
		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000000201" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[2. Stacked bar (chartType="bar" stacked="true") — the stack variant is a property, not a separate type]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000000202" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="bar" stacked="true">
					<titleExpression><![CDATA["Monthly Sales (stacked)"]]></titleExpression>
					<categoryDataset>
						<datasetRun uuid="2e000000-0000-0000-0000-000000000203" subDataset="sales">
							<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRMapCollectionDataSource($P{salesRecords})]]></dataSourceExpression>
						</datasetRun>
						<series>
							<seriesExpression><![CDATA[$F{product}]]></seriesExpression>
							<categoryExpression><![CDATA[$F{month}]]></categoryExpression>
							<valueExpression><![CDATA[$F{amount}]]></valueExpression>
						</series>
					</categoryDataset>
				</component>
			</element>
		</band>

