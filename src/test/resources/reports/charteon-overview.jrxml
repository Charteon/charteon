		<field name="median" class="java.lang.Double"/>
		<field name="q3" class="java.lang.Double"/>
		<field name="max" class="java.lang.Double"/>
	</dataset>

	<dataset name="ohlc" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a11">
		<field name="day" class="java.lang.String"/>
		<field name="open" class="java.lang.Double"/>
		<field name="close" class="java.lang.Double"/>
		<field name="low" class="java.lang.Double"/>
		<field name="high" class="java.lang.Double"/>
	</dataset>

	<dataset name="heat" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a12">
		<field name="day" class="java.lang.String"/>
		<field name="slot" class="java.lang.String"/>
