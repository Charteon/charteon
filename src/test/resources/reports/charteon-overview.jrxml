<?xml version="1.0" encoding="UTF-8"?>
<!--
  Charteon overview report: demonstrates every chart type supported by the
  Charteon component, grouped into Basic / Statistical / Hierarchy & Network /
  Geo / Special / Escape hatch. Filled by CharteonComponentFillTest and
  exported to PDF (vector) and HTML (interactive).
-->
<jasperReport name="charteon-overview" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a01">

	<dataset name="sales" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a02">
		<field name="month" class="java.lang.String"/>
		<field name="product" class="java.lang.String"/>
		<field name="amount" class="java.lang.Integer"/>
	</dataset>

	<dataset name="shares" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a03">
		<field name="name" class="java.lang.String"/>
		<field name="value" class="java.lang.Integer"/>
	</dataset>

	<dataset name="points" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a04">
		<field name="cluster" class="java.lang.String"/>
		<field name="x" class="java.lang.Double"/>
		<field name="y" class="java.lang.Double"/>
		<field name="size" class="java.lang.Double"/>
	</dataset>

	<dataset name="steps" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a05">
		<field name="name" class="java.lang.String"/>
		<field name="value" class="java.lang.Integer"/>
	</dataset>

	<dataset name="kpis" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a06">
		<field name="name" class="java.lang.String"/>
		<field name="value" class="java.lang.Double"/>
	</dataset>

	<dataset name="nodes" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a07">
		<field name="name" class="java.lang.String"/>
		<field name="parent" class="java.lang.String"/>
		<field name="value" class="java.lang.Integer"/>
	</dataset>

	<dataset name="flows" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a08">
		<field name="source" class="java.lang.String"/>
		<field name="target" class="java.lang.String"/>
		<field name="value" class="java.lang.Integer"/>
	</dataset>

	<dataset name="routes" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a09">
		<field name="source" class="java.lang.String"/>
		<field name="target" class="java.lang.String"/>
		<field name="value" class="java.lang.Integer"/>
		<field name="sx" class="java.lang.Double"/>
		<field name="sy" class="java.lang.Double"/>
		<field name="tx" class="java.lang.Double"/>
		<field name="ty" class="java.lang.Double"/>
	</dataset>

	<dataset name="boxes" uuid="0e1c3a52-8a3f-4f24-9d2e-2f9f7c8b4a10">
		<field name="category" class="java.lang.String"/>
		<field name="min" class="java.lang.Double"/>
