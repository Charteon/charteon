							<seriesExpression><![CDATA[$F{product}]]></seriesExpression>
							<categoryExpression><![CDATA[$F{month}]]></categoryExpression>
							<valueExpression><![CDATA[$F{amount}]]></valueExpression>
						</series>
					</categoryDataset>
				</component>
			</element>
		</band>

