			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000002501" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[15. Candlestick (chartType="candlestick") — candlestickDataset with open/close/low/high per category]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000002502" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="candlestick">
					<titleExpression><![CDATA["Share Price (OHLC)"]]></titleExpression>
					<candlestickDataset>
						<datasetRun uuid="2e000000-0000-0000-0000-000000002503" subDataset="ohlc">
