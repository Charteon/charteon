		</band>

		<!-- 6. Step line -->
		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000000601" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[6. Step line (chartType="line" step="middle") — discrete level changes]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000000602" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="line" step="middle">
