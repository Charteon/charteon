			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000002201" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[12. Bubble (chartType="scatter" + sizeExpression) — the third dimension drives the symbol size]]></text>
			</element>
