		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000000801" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[8. Doughnut (chartType="pie" innerRadius="45%") — the ring variant is just a pie property]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000000802" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="pie" innerRadius="45%">
					<titleExpression><![CDATA["Revenue Share (doughnut)"]]></titleExpression>
					<categoryDataset>
