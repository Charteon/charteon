							<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRMapCollectionDataSource($P{shareRecords})]]></dataSourceExpression>
						</datasetRun>
						<series>
							<seriesExpression><![CDATA["Revenue"]]></seriesExpression>
							<categoryExpression><![CDATA[$F{name}]]></categoryExpression>
							<valueExpression><![CDATA[$F{value}]]></valueExpression>
						</series>
					</categoryDataset>
				</component>
			</element>
		</band>

		<!-- 9. Rose pie -->
		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000001901" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[9. Nightingale rose (chartType="pie" roseType="area") — slice radius encodes the value]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000001902" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="pie" roseType="area" innerRadius="20%">
					<titleExpression><![CDATA["Revenue Share (rose)"]]></titleExpression>
					<categoryDataset>
