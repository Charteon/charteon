		<!-- 11. Scatter -->
		<band height="345">
			<element kind="staticText" uuid="2e000000-0000-0000-0000-000000002101" x="0" y="0" width="535" height="34" fontSize="12.0" bold="true">
				<text><![CDATA[11. Scatter (chartType="scatter") — xyDataset with x/y value expressions]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000002102" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="scatter">
