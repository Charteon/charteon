				<text><![CDATA[5. Area (chartType="line" filled="true" smooth="true") — smoothed line with filled area]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000000502" x="0" y="40" width="535" height="300">
				<component kind="chart" chartType="line" filled="true" smooth="true">
					<titleExpression><![CDATA["Monthly Sales (smoothed area)"]]></titleExpression>
					<categoryDataset>
						<datasetRun uuid="2e000000-0000-0000-0000-000000000503" subDataset="sales">
							<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRMapCollectionDataSource($P{salesRecords})]]></dataSourceExpression>
						</datasetRun>
						<series>
							<seriesExpression><![CDATA[$F{product}]]></seriesExpression>
							<categoryExpression><![CDATA[$F{month}]]></categoryExpression>
							<valueExpression><![CDATA[$F{amount}]]></valueExpression>
						</series>
					</categoryDataset>
