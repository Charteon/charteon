				<text><![CDATA[14. Boxplot (chartType="boxplot") — boxplotDataset with the five-number summary per category]]></text>
			</element>
			<element kind="component" uuid="2e000000-0000-0000-0000-000000002402" x="0" y="40" width="535" height="300">
